VITE_DEFAULT_THEME="light-theme"
VITE_DEFAULT_COLOR="blue-color"
VITE_DEFAULT_DIRECTION="ltr"
VITE_APP_NAME="FlexFit"
VITE_APP_DESCRIPTION="A gym app for tracking fitness and workouts"

# ─── Production / Render defaults ───────────────────────────────────────────
# These values are used when deployed to Render (or any public host).
# Override locally via frontend/.env.local (not committed to git).
VITE_API_BASE="https://dev-asterisks-github.onrender.com"

# Set to "true" only on localhost to bypass authentication for rapid testing.
VITE_DEBUG_NO_AUTH="false"